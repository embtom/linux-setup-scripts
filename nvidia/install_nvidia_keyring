#!/usr/bin/bash

set -euo pipefail

KEYRING_URL="https://developer.download.nvidia.com/compute/cuda/repos/debian12/x86_64/cuda-keyring_1.1-1_all.deb"
TMP_DEB="/tmp/cuda-keyring.deb"

echo "Downloading CUDA keyring..."
wget -O "$TMP_DEB" "$KEYRING_URL"

echo "Installing CUDA keyring..."
sudo dpkg -i "$TMP_DEB"

rm -f "$TMP_DEB"

echo "CUDA keyring installed successfully."
